# glassrail — example environment configuration.
# Copy to .env (which is gitignored) and edit. Every var is optional; defaults
# are documented in src/glassrail/config/.

# --- State ---
# GLASSRAIL_STATE_PATH=./state.sqlite

# --- Logging ---
# GLASSRAIL_LOG_LEVEL=INFO
# GLASSRAIL_LOG_JSON=false

# --- LLM tiers (provider endpoints + model names) ---
# Tier 0: local
# GLASSRAIL_TIER0_BASE_URL=http://localhost:8080/v1
# GLASSRAIL_TIER0_MODEL=qwen3.6-35b-moe
# GLASSRAIL_TIER0_TIMEOUT_S=10.0

# Tier 1: cheap cloud
# GLASSRAIL_TIER1_BASE_URL=https://openrouter.ai/api/v1
# GLASSRAIL_TIER1_MODEL=deepseek/deepseek-v4-flash
# GLASSRAIL_TIER1_API_KEY=

# Tier 2: capable cloud
# GLASSRAIL_TIER2_MODEL=deepseek/deepseek-v4-pro

# Tier 3: top-tier cloud
# GLASSRAIL_TIER3_MODEL=anthropic/claude-sonnet-4-6

# --- Plan limits ---
# GLASSRAIL_MAX_PLAN_STEPS=12
# GLASSRAIL_MAX_SUBPLANS_PER_PLAN=2
# GLASSRAIL_MAX_SUBPLAN_STEPS=12
# GLASSRAIL_MAX_DECISION_NESTING_DEPTH=2

# --- HITL ---
# GLASSRAIL_CONFIRM_PLANS=false
