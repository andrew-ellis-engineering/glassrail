# dagagent — example environment configuration.
# Copy to .env (which is gitignored) and edit. Every var is optional; defaults
# are documented in src/dagagent/config/.

# --- State ---
# DAGAGENT_STATE_PATH=./state.sqlite

# --- Logging ---
# DAGAGENT_LOG_LEVEL=INFO
# DAGAGENT_LOG_JSON=false

# --- LLM tiers (provider endpoints + model names) ---
# Tier 0: local
# DAGAGENT_TIER0_BASE_URL=http://localhost:8080/v1
# DAGAGENT_TIER0_MODEL=qwen3.6-35b-moe
# DAGAGENT_TIER0_TIMEOUT_S=10.0

# Tier 1: cheap cloud
# DAGAGENT_TIER1_BASE_URL=https://openrouter.ai/api/v1
# DAGAGENT_TIER1_MODEL=deepseek/deepseek-v4-flash
# DAGAGENT_TIER1_API_KEY=

# Tier 2: capable cloud
# DAGAGENT_TIER2_MODEL=deepseek/deepseek-v4-pro

# Tier 3: top-tier cloud
# DAGAGENT_TIER3_MODEL=anthropic/claude-sonnet-4-6

# --- Plan limits ---
# DAGAGENT_MAX_PLAN_STEPS=12
# DAGAGENT_MAX_SUBPLANS_PER_PLAN=2
# DAGAGENT_MAX_SUBPLAN_STEPS=12
# DAGAGENT_MAX_DECISION_NESTING_DEPTH=2

# --- HITL ---
# DAGAGENT_CONFIRM_PLANS=false
